{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fdgf.local/schemas/lineage_event.schema.json",
  "title": "FDGF Lineage Bundle",
  "type": "object",
  "required": [
    "bundle_type",
    "run_id",
    "job_name",
    "job_namespace",
    "regulatory_scope",
    "inputs",
    "outputs",
    "transformations",
    "lineage_fingerprint"
  ],
  "properties": {
    "bundle_type": { "type": "string" },
    "run_id": { "type": "string" },
    "job_name": { "type": "string" },
    "job_namespace": { "type": "string" },
    "regulatory_scope": { "type": "string" },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dataset_fingerprint", "dataset_fingerprint_method"],
        "properties": {
          "dataset_fingerprint": { "type": "string" },
          "dataset_fingerprint_method": {
            "type": "string",
            "description": "Fingerprint method emitted for this dataset facet. The method depends on whether the source is a local file or a metadata-only dataset reference.",
            "enum": ["sha256_file_content", "metadata_shape_fingerprint"]
          }
        },
        "additionalProperties": true
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dataset_fingerprint", "dataset_fingerprint_method"],
        "properties": {
          "dataset_fingerprint": { "type": "string" },
          "dataset_fingerprint_method": {
            "type": "string",
            "description": "Fingerprint method emitted for this dataset facet. The method depends on whether the source is a local file or a metadata-only dataset reference.",
            "enum": ["sha256_file_content", "metadata_shape_fingerprint"]
          }
        },
        "additionalProperties": true
      }
    },
    "transformations": { "type": "array" },
    "lineage_fingerprint": { "type": "string" }
  },
  "additionalProperties": true
}
